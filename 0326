<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <script crossorigin src="https://unpkg.com/react@18/umd/react.development.js"></script>
    <script crossorigin src="https://unpkg.com/react-dom@18/umd/react-dom.development.js"></script>
    <script crossorigin src="https://unpkg.com/@babel/standalone/babel.min.js"></script>
</head>

<body>
    <div id="root"></div>
    <script type="text/babel">
        // 연습1) 아래 변수에 저장된 값을 <div> 태그로 화면에 표시하세요.
        const name = 'Tom';

        // 연습2) 아래 객체에 저장된 값 중 model 속성만 <div> 태그로 화면에 표시하세요.
        const car = {
            model: 'sorento',
            price: 4000,
        }

        // 연습3) 아래 score 값이 60 이상이면 "합격", 아니면 "불합격"을 <div> 태그로 화면에 표시하세요.
        const score = 80;

        const resultMessage = score >= 60
            ? <span>합격</span>
            : <span>불합격</span>

        // 연습4) 아래 변수에 저장된 값이 없으면 "값없음", 값이 있으면 저장된 값을 <div> 태그로 화면에 표시하세요.
        let value;
        // value = 5;

        // 연습5) 아래 color 값이 "r"이면 "red", "g"이면 "green", "b"이면 "blue" 배경색을 <div> 태그에 적용해 화면에 표시하세요.
        // (100 x 100 크기)
        const color = 'r';

        let backgroundColor;
        if (color === 'r') backgroundColor = 'red';
        else if (color === 'g') backgroundColor = 'green';
        else if (color === 'b') backgroundColor = 'blue';

        const boxSize = {
            width: '100px',
            height: '100px',
            backgroundColor: backgroundColor
        };

        const App = () => {
            return (
                <div>
                    <div>{name}</div>
                    <div>{car.model}</div>
                    <div>{resultMessage}</div>
                    <div>{value ? value : "값없음"}</div>
                    <div style={boxSize}></div>
                </div>
            );
        };

        ReactDOM.createRoot(document.getElementById('root')).render(<App />);

    </script>
</body>

</html>
